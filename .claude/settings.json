{
  "enabledPlugins": {
    "postgres-best-practices@supabase-agent-skills": true
  },
  "permissions": {
    "allow": [
      "Bash(git push --force-with-lease)",
      "Bash(git push --force-with-lease:*)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force:*)",
      "Bash(git push -f)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd)",
      "Bash(git clean -fd:*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.development)",
      "Read(./.env.production)",
      "Read(./.env.*.local)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/block-env-read.py"
          }
        ]
      }
    ]
  }
}
