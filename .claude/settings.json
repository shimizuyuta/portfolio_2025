{
  "enabledPlugins": {
    "postgres-best-practices@supabase-agent-skills": true
  },
  "permissions": {
    "allow": [
      "Bash(git push --force-with-lease)",
      "Bash(git push --force-with-lease:*)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force:*)",
      "Bash(git push -f)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd)",
      "Bash(git clean -fd:*)"
    ]
  }
}
